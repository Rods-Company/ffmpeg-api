NODE_ENV=development
LOG_LEVEL=info
SERVER_PORT=3000
EXTERNAL_PORT=3000
PUBLIC_BASE_URL=
FILE_SIZE_LIMIT_BYTES=536870912
KEEP_ALL_FILES=false
ENABLE_SYNC_SMALL_JOBS=true
SYNC_MAX_INPUT_BYTES=10485760
JOB_CONCURRENCY=2
MAX_QUEUE_SIZE=100
JOB_RETENTION_MS=900000
JOB_TIMEOUT_MS=3600000
DOWNLOAD_TIMEOUT_MS=60000
URL_MAX_REDIRECTS=5
ALLOW_PRIVATE_URLS=false
JSON_BODY_LIMIT=1mb
AUDIO_ACTIVITY_NOISE_THRESHOLD_DB=-35
AUDIO_ACTIVITY_MIN_SILENCE_DURATION=0.5
AUDIO_ACTIVITY_MIN_SEGMENT_DURATION=1.2
AUDIO_ACTIVITY_MIN_ACTIVE_RATIO=0.08
AUDIO_ACTIVITY_USE_SPEECH_BAND=true
SCALAR_THEME=elysiajs
SCALAR_TITLE=ffmpeg-api
SCALAR_TELEMETRY=true
SCALAR_LAYOUT=modern
SHOW_STARTUP_BANNER=true
